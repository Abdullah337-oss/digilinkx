PORT=5000
JWT_SECRET=your_secret_key_change_this_in_production
NODE_ENV=development

# Supabase Postgres for users, login, boards, cards, comments, etc.
# Use the Supabase database connection string, not the REST API URL.
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase Storage for attachments.
# SUPABASE_URL can be either https://your-project.supabase.co
# or the REST URL from Supabase, e.g. https://your-project.supabase.co/rest/v1/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_STORAGE_BUCKET=uploads
